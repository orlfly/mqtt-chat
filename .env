# MQTT Configuration
# Set explicit ws:// URL for dev (direct to EMQX WebSocket port)
# For nginx deployment, comment out this line to use dynamic URL (ws://nginx-host/mqtt)
#REACT_APP_MQTT_BROKER_URL=ws://localhost:8083/mqtt
REACT_APP_MQTT_USERNAME=web
REACT_APP_MQTT_PASSWORD=web
REACT_APP_MQTT_CLIENT_ID=web-viewer
REACT_APP_MQTT_CONNECT_TIMEOUT=30000
REACT_APP_MQTT_RECONNECT_PERIOD=5000

# EMQX API Configuration
# Use relative path /api/emqx for both dev and nginx deployment
# Dev: setupProxy.js proxies /api/emqx -> http://localhost:18083/api/v5
# Prod: nginx proxies /api/emqx -> http://localhost:18083/api/v5
REACT_APP_EMQX_BASE_URL=/api/emqx
REACT_APP_EMQX_API_KEY=334debcfbdc435a8
REACT_APP_EMQX_API_SECRET=7PK5Qzq1QNQG4AICorO12gfs9CnlywGfI3ccJ05kxfSD
