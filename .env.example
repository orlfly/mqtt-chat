# MQTT Configuration
REACT_APP_MQTT_BROKER_URL=ws://localhost:8083/mqtt
REACT_APP_MQTT_USERNAME=admin
REACT_APP_MQTT_PASSWORD=public
REACT_APP_MQTT_CLIENT_ID=mqtt-chat-client
REACT_APP_MQTT_CONNECT_TIMEOUT=30000
REACT_APP_MQTT_RECONNECT_PERIOD=5000

# EMQX API Configuration
REACT_APP_EMQX_BASE_URL=http://localhost:18083
REACT_APP_EMQX_API_KEY=your-emqx-api-key
REACT_APP_EMQX_API_SECRET=your-emqx-api-secret

# Development Proxy Configuration
REACT_APP_DEV_PROXY_PATH=/api/v5